{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.2"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/admin/(.*)", "dest": "/admin/$1.php" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/(.*)", "dest": "/$1.php" }
  ]
}
