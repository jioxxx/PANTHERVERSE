{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.php",
      "use": "vercel-php@latest"
    },
    {
      "src": "*.php",
      "use": "vercel-php@latest"
    },
    {
      "src": "admin/**/*.php",
      "use": "vercel-php@latest"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/admin/(.*)", "dest": "/admin/$1.php" },
    { "src": "/(.*)", "dest": "/$1.php" }
  ]
}
