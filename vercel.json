{
  "version": 2,
  "builds": [
    {"src": "api/**/*.php", "use": "@vercel/php@latest"},
    {"src": "*.php", "use": "@vercel/php@latest"},
    {"src": "admin/**/*.php", "use": "@vercel/php@latest"}
  ],
  "routes": [
    {"src": "/assets/**", "headers": {"Cache-Control": "public, max-age=31536000"}},
    {"src": "/assets/(.*)", "dest": "/assets/$1"},
    {"src": "/admin/(.*)", "dest": "/admin/$1.php"},
    {"src": "/((?!assets|admin).*)", "dest": "/$1.php"}
  ],
  "headers": [
    {"source": "/**", "headers": [{"key": "Cache-Control", "value": "no-cache, no-store, must-revalidate, max-age=0"}]}
  ]
}
